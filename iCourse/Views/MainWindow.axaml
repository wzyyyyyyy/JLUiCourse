<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:iCourse.Views"
        x:Class="iCourse.Views.MainWindow"
        Title="iCourse"
        Width="980"
        Height="560"
        MinWidth="900"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="#1F1F1F">
  <Window.Styles>
    <Style Selector="Border.status-badge">
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="9,4" />
      <Setter Property="MinWidth" Value="64" />
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="Background" Value="#525967" />
    </Style>
    <Style Selector="Border.status-badge.waiting">
      <Setter Property="Background" Value="#525967" />
    </Style>
    <Style Selector="Border.status-badge.racing">
      <Setter Property="Background" Value="#1769AA" />
    </Style>
    <Style Selector="Border.status-badge.backoff">
      <Setter Property="Background" Value="#9A6700" />
    </Style>
    <Style Selector="Border.status-badge.success">
      <Setter Property="Background" Value="#237A45" />
    </Style>
    <Style Selector="Border.status-badge.failure">
      <Setter Property="Background" Value="#A13A3A" />
    </Style>
    <Style Selector="Border.selection-banner">
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="12,9" />
    </Style>
    <Style Selector="Border.selection-banner.info">
      <Setter Property="Background" Value="#173A54" />
      <Setter Property="BorderBrush" Value="#4C9ED9" />
    </Style>
    <Style Selector="Border.selection-banner.warning">
      <Setter Property="Background" Value="#5A4315" />
      <Setter Property="BorderBrush" Value="#D6A443" />
    </Style>
    <Style Selector="Border.selection-banner.error">
      <Setter Property="Background" Value="#713939" />
      <Setter Property="BorderBrush" Value="#E47D7D" />
    </Style>
  </Window.Styles>

  <Grid ColumnDefinitions="220,*" Margin="18">
    <views:LoginControl />

    <Grid Grid.Column="1"
          RowDefinitions="Auto,Auto,*,Auto"
          Margin="20,0,0,0">
      <Grid Grid.Row="0"
            ColumnDefinitions="*,Auto,Auto,Auto,Auto"
            ColumnSpacing="14"
            Margin="0,0,0,12">
        <TextBlock Text="选课状态"
                   Foreground="#F5F7FA"
                   FontSize="22"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
          <TextBlock Text="总计" Foreground="#B8C0CC" />
          <TextBlock Text="{Binding TotalCount}" Foreground="#F5F7FA" FontWeight="SemiBold" />
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
          <TextBlock Text="进行中" Foreground="#79BFFF" />
          <TextBlock Text="{Binding RunningCount}" Foreground="#F5F7FA" FontWeight="SemiBold" />
        </StackPanel>
        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
          <TextBlock Text="成功" Foreground="#71D39A" />
          <TextBlock Text="{Binding SucceededCount}" Foreground="#F5F7FA" FontWeight="SemiBold" />
        </StackPanel>
        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
          <TextBlock Text="失败" Foreground="#FF9696" />
          <TextBlock Text="{Binding FailedCount}" Foreground="#F5F7FA" FontWeight="SemiBold" />
        </StackPanel>
      </Grid>

      <Border Grid.Row="1"
              Classes="selection-banner"
              Classes.info="{Binding IsBannerInfo}"
              Classes.warning="{Binding IsBannerWarning}"
              Classes.error="{Binding IsBannerError}"
              IsVisible="{Binding IsBannerVisible}"
              Margin="0,0,0,12">
        <TextBlock Text="{Binding BannerText}"
                   Foreground="#FFF4F4"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap" />
      </Border>

      <DataGrid Grid.Row="2"
                ItemsSource="{Binding CourseStatuses}"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                CanUserResizeColumns="True"
                CanUserReorderColumns="False"
                CanUserSortColumns="False"
                GridLinesVisibility="Horizontal"
                BorderBrush="#454A53"
                BorderThickness="1"
                Background="#282B30"
                RowBackground="#282B30"
                HorizontalGridLinesBrush="#454A53">
        <DataGrid.Columns>
          <DataGridTemplateColumn Header="课程" Width="2*">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding CourseName}"
                           TextWrapping="Wrap"
                           MaxLines="2"
                           ToolTip.Tip="{Binding CourseName}"
                           VerticalAlignment="Center" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="状态" Width="96">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Border Classes="status-badge"
                        Classes.waiting="{Binding IsWaiting}"
                        Classes.racing="{Binding IsRacing}"
                        Classes.backoff="{Binding IsBackingOff}"
                        Classes.success="{Binding IsSucceeded}"
                        Classes.failure="{Binding IsFailed}">
                  <TextBlock Text="{Binding StateText}"
                             Foreground="#FFFFFF"
                             FontWeight="SemiBold"
                             HorizontalAlignment="Center" />
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="尝试次数"
                              Binding="{Binding AttemptCount}"
                              Width="76" />
          <DataGridTextColumn Header="耗时"
                              Binding="{Binding ElapsedText}"
                              Width="76" />
          <DataGridTemplateColumn Header="最新结果" Width="3*">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding LatestResult}"
                           TextWrapping="Wrap"
                           MaxLines="2"
                           ToolTip.Tip="{Binding LatestResult}"
                           VerticalAlignment="Center" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>

      <ProgressBar Grid.Row="3"
                   Margin="0,12,0,0"
                   Height="5"
                   IsVisible="{Binding IsProgressVisible}"
                   Minimum="0"
                   Maximum="100"
                   Value="{Binding ProgressValue}" />
    </Grid>
  </Grid>
</Window>
